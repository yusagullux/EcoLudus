# Primary connection string for local development.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD-URL-ENCODED]@db.[PROJECT-REF].supabase.co:5432/postgres

# Required for login sessions (use a long random string).
SESSION_SECRET=replace-with-a-long-random-secret

# SSL for Supabase/Postgres hosts (auto-detected for supabase.co if omitted).
POSTGRES_SSL=true

# Force Postgres instead of the local file fallback.
LOCAL_DB_MODE=postgres

# Optional: verified carbon estimates (falls back to quests.json without it).
CLIMATIQ_API_KEY=

# Optional: Gemini AI for quest proof + private mission verification.
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: Ecologi API for real-world tree planting when users hit milestones.
# Sign up at https://ecologi.com and get your API key from the dashboard.
ECOLOGI_API_KEY=

# Secret used to authenticate nightly cron jobs (use a long random string).
# POST /api/cron/process-rewards with Authorization: Bearer <CRON_SECRET>
CRON_SECRET=replace-with-a-long-random-cron-secret

# Optional: SendGrid for weekly impact emails (free: 100 emails/day).
# Sign up at https://sendgrid.com — add a verified sender identity first.
SENDGRID_API_KEY=
SENDGRID_FROM=hello@ecoludus.com

# Vercel + Supabase integration: if DATABASE_URL is unset, the app also reads
# POSTGRES_URL / POSTGRES_URL_NON_POOLING injected by Vercel automatically.
